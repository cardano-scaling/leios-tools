# duplex-follower-bug.bt — reproduce the original duplex-follower crash:
# a size-zero EB offer reflected back to its source. echo-to-source and
# lie-about-eb-size write distinct LeiosControl fields, so a Join applies both
# concurrently (no ordering — unlike the old hook composition).
run {
  name = "duplex-follower-bug"
  seed = 0
}

root [
  Join[
    Action("echo-to-source"),
    Action("lie-about-eb-size", scale_num = 0, scale_den = 1, offset = 0)
  ]
]
