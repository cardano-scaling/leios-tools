BT_FILES = $(wildcard lib/*.bt attacks/*.bt)

# Round-trip is *semantic* — comments and formatting are not preserved — so we don't
# diff the source against the round-trip. Instead we test idempotence per file: once a
# file has been through bt->toml->bt it must be stable (translating it again is a no-op).
# Covers both lib/ (pure behaviours/fragments) and attacks/ (runnable attacks).
#
# Make notes: `$(BT_FILES)` is a Make variable; `$$` is a literal `$` for the shell, so
# `$$$$` is the shell PID and `$$f`/`$$t`/`$$fail` are shell variables. The whole loop is
# one shell (joined with `\`) so the PID-based temp prefix is consistent throughout. The
# temp name sanitises the path (`lib/x.bt` -> `lib_x_bt`) so files in different dirs don't
# collide.
test:
	@fail=0; \
	for f in $(BT_FILES); do \
	  t=/tmp/bt-$$$$-$$(echo $$f | sed 's#[/.]#_#g'); \
	  if ./bt.py $$f > $$t.toml \
	     && ./bt.py --toml-to-bt $$t.toml > $$t.bt \
	     && ./bt.py $$t.bt > $$t.toml2 \
	     && diff -q $$t.toml $$t.toml2 >/dev/null; then \
	    echo "ok    $$f"; \
	  else \
	    echo "FAIL  $$f"; diff $$t.toml $$t.toml2 2>/dev/null || true; fail=1; \
	  fi; \
	  rm -f $$t.toml $$t.bt $$t.toml2; \
	done; \
	exit $$fail

# Full-resolution test: not a round trip (it merges an attack with its includes into one
# self-contained TOML), so we compare `--resolve` output against a committed golden file.
# Regenerate the golden with: make bless-resolve
RESOLVE_ATTACK = attacks/long-range-fork-attack.bt
RESOLVE_GOLDEN = expected/long-range-fork-attack.toml
test-resolve:
	@./bt.py --resolve --include-path lib $(RESOLVE_ATTACK) | diff - $(RESOLVE_GOLDEN) \
	  && echo "ok    resolve $(RESOLVE_ATTACK)" \
	  || { echo "FAIL  resolve $(RESOLVE_ATTACK) (differs from $(RESOLVE_GOLDEN); run 'make bless-resolve' if intended)"; exit 1; }

bless-resolve:
	@./bt.py --resolve --include-path lib $(RESOLVE_ATTACK) > $(RESOLVE_GOLDEN)
	@echo "blessed $(RESOLVE_GOLDEN)"

# --- Generated consumer configs ------------------------------------------------
# The runnable lib/*.bt files are the SOURCE OF TRUTH for the behaviour-tree
# configs the node + simulator load. `make configs` resolves each (includes
# expanded, self-contained) and writes it to the consumer path(s) with a
# generated-from header. Workflow: edit the .bt source, `make configs`, commit
# both. `make check-configs` (run in CI) fails if a committed config has drifted
# from its source.
#
# Mapping below is `<lib source>:<consumer destination>` (one per line; the same
# source may feed several consumers). The honest leaf is the `Action("honest")`
# .bt syntax (resolves to the engine's `type = "HonestAction"`).
NET_BEH = ../net-rs/net-cluster/behaviours
SIM_BEH = ../sim-rs/parameters/behaviours
CONFIG_MAP = \
  lib/honest.bt:$(NET_BEH)/honest.toml \
  lib/lazy-voter.bt:$(NET_BEH)/lazy-voter.toml \
  lib/lazy-voter.bt:$(SIM_BEH)/lazy-voter.toml \
  lib/rb-header-equivocator.bt:$(NET_BEH)/rb-equivocator.toml \
  lib/t22.bt:$(NET_BEH)/t22.toml \
  lib/duplex-follower-bug.bt:$(NET_BEH)/duplex-follower-bug.toml

configs:
	@for pair in $(CONFIG_MAP); do \
	  src=$${pair%%:*}; dest=$${pair#*:}; \
	  { printf '# GENERATED by `make configs` from behaviours/%s — do not edit by hand.\n' "$$src"; \
	    ./bt.py --resolve --include-path lib "$$src"; } > "$$dest" \
	    && echo "wrote $$dest  (from $$src)" \
	    || { echo "FAIL  resolving $$src"; exit 1; }; \
	done

check-configs:
	@fail=0; \
	for pair in $(CONFIG_MAP); do \
	  src=$${pair%%:*}; dest=$${pair#*:}; \
	  tmp=/tmp/btcfg-$$$$-$$(echo "$$dest" | sed 's#[/.]#_#g'); \
	  { printf '# GENERATED by `make configs` from behaviours/%s — do not edit by hand.\n' "$$src"; \
	    ./bt.py --resolve --include-path lib "$$src"; } > "$$tmp"; \
	  if diff -q "$$tmp" "$$dest" >/dev/null 2>&1; then \
	    echo "ok    $$dest"; \
	  else \
	    echo "DRIFT $$dest (regenerate with 'make configs')"; diff "$$dest" "$$tmp" 2>/dev/null || true; fail=1; \
	  fi; \
	  rm -f "$$tmp"; \
	done; \
	exit $$fail

check: test test-resolve check-configs

.PHONY: test test-resolve bless-resolve check configs check-configs
